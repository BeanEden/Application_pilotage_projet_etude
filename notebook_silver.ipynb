        "\n",
        "print(f\"[CONFIG] Workspace  : {WORKSPACE_NAME}\")\n",
        "print(f\"[CONFIG] Lakehouse  : {LAKEHOUSE_NAME}\")\n",
        "print(f\"[CONFIG] Timestamp  : {SILVER_TIMESTAMP.isoformat()}\")\n",
        "print(f\"[CONFIG] Run ID     : {SILVER_RUN_ID}\")"
      ]
