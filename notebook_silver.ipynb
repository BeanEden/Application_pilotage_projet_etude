        "    .withColumn(\"silver_client_id_calc\", udf_id(F.col(\"cle_client\")))\n",
        "    .withColumn(\"com_norm\",\n",
        "        F.trim(F.regexp_replace(F.coalesce(F.col(\"commercial_nom_raw\"), F.lit(\"\")), r'\\s+', ' ')))\n",
