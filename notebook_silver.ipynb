        "nb_remise_forte = df_lignes_typed.filter(\n",
        "    F.col(\"remise_pct\").isNotNull() & (F.col(\"remise_pct\") > 50) & (F.col(\"remise_pct\") <= 100)\n",
        ").count()\n",
